@model IEnumerable<EduCore.Models.Trainee>

@{
	ViewData["Title"] = "ShowAll";
}

<h1>Show All Trainees</h1>

<p>
	<a asp-action="Create" class="btn btn-success">Create New Trainee</a>
</p>
<table class="table">
	<thead>
		<tr>
			<th>
				@Html.DisplayNameFor(model => model.Name)
			</th>
@* 			<th>
				@Html.DisplayNameFor(model => model.Image)
			</th> *@
			<th>
				@Html.DisplayNameFor(model => model.Address)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Grade)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Department)
			</th>
			<th>
				Action
			</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					@Html.DisplayFor(model => item.Name)
				</td>
@* 				<td>
					@Html.DisplayFor(model => item.Image)
				</td> *@
				<td>
					@Html.DisplayFor(model => item.Address)
				</td>
				<td>
					@Html.DisplayFor(model => item.Grade)
				</td>
				<td>
					@Html.DisplayFor(model => item.Department.Name)
				</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary">Edit</a> |
					<a asp-action="GetById" asp-route-id="@item.Id" class="btn btn-info">Details</a> |
					<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a> |
					<a asp-action="Results" asp-route-id="@item.Id" class="btn btn-secondary">Results</a>
				</td>
			</tr>
		}
	</tbody>
</table>
