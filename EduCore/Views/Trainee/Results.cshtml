@model IEnumerable<EduCore.Models.ViewModel.ResultsViewModel>

@{
	ViewData["Title"] = "Results";
}

<h1>Show Results</h1>

<table class="table">
	<thead>
		<tr>
			<th>
				@Html.DisplayNameFor(model => model.CourseName)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.Degree)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.MinDegree)
			</th>
			<th>
				@Html.DisplayNameFor(model => model.status)
			</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					@Html.DisplayFor(model => item.CourseName)
				</td>
				<td>
					@Html.DisplayFor(model => item.Degree)
				</td>
				<td>
					@Html.DisplayFor(model => item.MinDegree)
				</td>
				<td>
					@Html.DisplayFor(model => item.status)
				</td>
			</tr>
		}
	</tbody>
</table>
<div>
	<a asp-action="ShowAll" class="btn btn-secondary">Back to List</a>
</div>

