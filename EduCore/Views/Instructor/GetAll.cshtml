@model List<Instructor>
<h1>Show All Instructors</h1>
<div class="mb-3">
	<a asp-action="Create" class="btn btn-success">Create New Instructor</a>
</div>
<table class="table table-bordered table-hover">
	<thead>
		<tr>
			<th>ID</th>
			<th>Name</th>
			<th>Action</th>
		</tr>
	</thead>
	<tbody>
		@foreach (Instructor item in Model)
		{
			<tr>
				<td>@item.Id</td>
				<td>@item.Name</td>
				<td>
					<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary">Edit</a> |
					<a asp-action="GetById" asp-route-id="@item.Id" class="btn btn-info">Details</a> |
					<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>