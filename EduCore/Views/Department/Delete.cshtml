@model EduCore.Models.Department
<h1>Delete Department</h1>
<p>Are you sure you want to delete this Department?</p>
<form method="post" asp-action="DeleteConfirmed" asp-controller="Department">
	<input asp-for="Id" type="hidden" />
	<button type="submit" class="btn btn-danger">Yes, Delete</button>
	<a href="/Department/ShowAll" class="btn btn-secondary">Cancel</a>
</form>