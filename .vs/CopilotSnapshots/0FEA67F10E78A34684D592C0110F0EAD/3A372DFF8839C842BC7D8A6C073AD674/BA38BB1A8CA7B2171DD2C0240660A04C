@model List<Course>
@{
}
<h1>Show All Courses</h1>
<a href="/Course/New" class="btn btn-primary">Add New Course</a>

<table class="table table-bordered table-hover">
	<thead>
		<tr>
			<th>ID</th>
			<th>Name</th>
			<th>Degree</th>
			<th>Min Degree</th>
			<th>Hours</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (Course item in Model)
		{
			<tr>
				<td>@item.Id</td>
				<td>@item.Name</td>
				<td>@item.Degree</td>
				<td>@item.MinDegree</td>
				<td>@item.Hours</td>
				<td>
					<a href="/Course/Edit/@item.Id" class="btn btn-primary">Edit</a>
					<a href="/Course/Delete/@item.Id" class="btn btn-danger">Delete</a>
				</td>
			</tr>
		}

	</tbody>
</table>